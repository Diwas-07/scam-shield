# AWS RDS (MySQL)
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=3306
RDS_DATABASE=scamshield
RDS_USER=admin
RDS_PASSWORD=your_db_password

# Set to 'true' to use demo data without a DB connection
USE_MOCK_DATA=false

# Application
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=production
